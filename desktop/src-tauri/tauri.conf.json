{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OH卡知识库",
  "mainBinaryName": "seeing-is-healing",
  "version": "0.1.0",
  "identifier": "com.ohcards.seeing-is-healing",
  "build": {
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "看见，即疗愈 · OH卡知识库",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["zh-CN", "en-US"]
      },
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "installMode": "perMachine"
      }
    },
    "category": "Education",
    "shortDescription": "OH 卡知识库桌面版",
    "longDescription": "看见，即疗愈 · OH 卡知识库 — 18 套卡牌、各种牌阵、引导问题。"
  }
}
