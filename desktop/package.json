{
  "name": "seeing-is-healing-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "看见，即疗愈 · OH 卡知识库 桌面客户端",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "serve-handler": "^6.1.6"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.ohcards.seeing-is-healing",
    "productName": "OH卡知识库",
    "asar": true,
    "compression": "normal",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../web/out",
        "to": "web",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico",
      "artifactName": "OH卡知识库-${version}-windows-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OH卡知识库",
      "installerLanguages": ["zh_CN", "en_US"]
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.education",
      "artifactName": "OH卡知识库-${version}-macos-${arch}.${ext}"
    },
    "dmg": {
      "title": "OH卡知识库 ${version}",
      "writeUpdateInfo": false
    }
  }
}
